{
  "uid": "vayunetra-model-perf",
  "title": "VayuNetra — Model Performance",
  "tags": ["vayunetra", "model"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Forecast RMSE by horizon (latest eval)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "vayunetra-prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "expr": "vayunetra_forecast_rmse",
          "legendFormat": "{{city}}/{{pollutant}} h{{horizon}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "bargauge",
      "title": "Lift vs persistence by horizon",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "vayunetra-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.08 },
              { "color": "green", "value": 0.15 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "vayunetra_forecast_lift_vs_persistence",
          "legendFormat": "{{city}}/{{pollutant}} h{{horizon}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Inference latency p95 by handler (s)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "vayunetra-prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(vayunetra_inference_latency_seconds_bucket[5m])) by (le, handler))",
          "legendFormat": "p95 {{handler}}",
          "refId": "A"
        }
      ]
    }
  ]
}
