{
  "uid": "vayunetra-ingestion-health",
  "title": "VayuNetra — Ingestion & Service Health",
  "tags": ["vayunetra", "ingestion", "health"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Scrape targets up",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "vayunetra-prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ]
        },
        "overrides": []
      },
      "targets": [
        { "expr": "up", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "API availability (up)",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "vayunetra-prometheus" },
      "fieldConfig": { "defaults": { "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        { "expr": "up{job=\"vayunetra-api\"}", "legendFormat": "api", "refId": "A" },
        { "expr": "up{job=\"prefect\"}", "legendFormat": "prefect", "refId": "B" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Total request throughput (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "vayunetra-prometheus" },
      "targets": [
        { "expr": "sum(rate(vayunetra_http_requests_total[5m]))", "legendFormat": "all", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Advisory & forecast endpoint traffic (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "vayunetra-prometheus" },
      "targets": [
        {
          "expr": "sum(rate(vayunetra_http_requests_total{handler=~\"/advisory.*|/forecast.*\"}[5m])) by (handler)",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ]
    }
  ]
}
