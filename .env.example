# Copy to .env and fill in. Never commit .env.

# ── Database ─────────────────────────────────────────
POSTGRES_USER=vayunetra
POSTGRES_PASSWORD=vayunetra_dev_change_me
POSTGRES_DB=vayunetra
POSTGRES_HOST=postgis
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://vayunetra:vayunetra_dev_change_me@postgis:5432/vayunetra

# ── Object store (MinIO) ─────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev_change_me
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=vayunetra
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin_dev_change_me
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MLflow ───────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── Prefect ──────────────────────────────────────────
PREFECT_API_URL=http://prefect-server:4200/api

# ── Data source API keys ─────────────────────────────
OPENAQ_API_KEY=
FIRMS_API_KEY=
CAMS_ADS_KEY=
CAMS_ADS_URL=https://ads.atmosphere.copernicus.eu/api/v2

# GEE: path to service account JSON (mounted into the api container)
GEE_SERVICE_ACCOUNT=
GEE_KEY_FILE=/run/secrets/gee_key.json

# ── LLM ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Bots ─────────────────────────────────────────────
TELEGRAM_TOKEN=

# ── Auth ─────────────────────────────────────────────
JWT_SECRET=change_me_in_prod_32_chars_min_abcdefgh
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=60

# ── Feature flags ────────────────────────────────────
ENABLE_LANGGRAPH=true
DEMO_MODE=false
LOG_LEVEL=INFO

# ── Observability ────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=vayunetra-api
